server:
  port: "8080"
  gin_mode: "release"
  base_path: ""
  read_timeout: "30s"
  write_timeout: "30s"
  max_body_size: 10485760

database:
  driver: "sqlite"
  path: "./data/app.db"
  url: ""
  # auto_schema: true   # set false when DBA creates tables separately; app only seeds data
  max_open_conns: 10
  max_idle_conns: 5
  conn_max_lifetime: "1h"

auth:
  jwt_secret: "CHANGE_ME_at_least_32_bytes_long_secret_key"
  jwt_expiry: "24h"
  initial_admin:
    username: "admin"
    password: "CHANGE_ME_initial_admin_password"

cors:
  origins:
    - "http://localhost:5173"

logging:
  level: "info"
  format: "json"
