# PM Work Tracker - Environment Variables

# --- Required ---
# JWT secret for signing tokens. Must be at least 32 bytes.
JWT_SECRET=

# --- Optional (with defaults) ---

# Database driver: "sqlite" (default) or "mysql"
DB_DRIVER=sqlite

# Database path (sqlite only). Default: ./data/dev.db
DB_PATH=./data/dev.db

# Database URL (mysql only). Required when DB_DRIVER=mysql.
# Format: user:password@tcp(host:port)/dbname
DATABASE_URL=

# Comma-separated list of allowed CORS origins.
# Example: http://localhost:3000,https://example.com
CORS_ORIGINS=

# Server port. Default: 8080
PORT=8080
